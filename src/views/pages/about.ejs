<!-- src/views/pages/about.ejs -->
<%- include('../partials/hero-mini', { 
    title: 'About Us',
    category: 'About',
    subtitle: 'Learn more about Pharmis Optimus Nexus and our mission to advance pharmaceutical knowledge and research.'
}) %>

<div class="about-page">
    <!-- Mission Section -->
    <section class="about-section">
        <div class="about-section-content">
            <div class="about-section-text">
                <div class="section-label">Our Mission</div>
                <h2 class="section-title">Advancing Pharmaceutical Knowledge for a Healthier World</h2>
                <div class="divider"></div>
                <p>Pharmis Optimus Nexus is a public health–driven platform founded by passionate 300-level pharmacy students committed to promoting health awareness, pharmaceutical knowledge, and community impact. Our mission is to educate, inform, and inspire individuals through evidence-based health information, research discussions, and public health advocacy.</p>
                <p>We aim to bridge the gap between pharmaceutical education and community healthcare by creating a space where students, healthcare enthusiasts, and professionals can share ideas, discuss emerging health challenges, and promote healthier lifestyles.</p>
            </div>
            <div class="about-section-image">
                <div class="about-image-placeholder" style="background: linear-gradient(135deg, var(--crimson), var(--blush));">
                    <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                        <path d="M2 17l10 5 10-5"/>
                        <path d="M2 12l10 5 10-5"/>
                    </svg>
                    <span>Pharmis Optimus Nexus</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Values Section -->
    <section class="about-section values-section">
        <div class="about-section-header">
            <div class="section-label">Our Values</div>
            <h2 class="section-title">What We Stand For</h2>
            <div class="divider"></div>
        </div>
        <div class="values-grid">
            <div class="value-card">
                <div class="value-icon">📚</div>
                <h3>Excellence</h3>
                <p>We strive for excellence in all we do, from research to community engagement.</p>
            </div>
            <div class="value-card">
                <div class="value-icon">🤝</div>
                <h3>Collaboration</h3>
                <p>We believe in the power of collaboration to drive innovation and progress.</p>
            </div>
            <div class="value-card">
                <div class="value-icon">🌍</div>
                <h3>Community Impact</h3>
                <p>We are committed to making a positive impact on communities through health education.</p>
            </div>
            <div class="value-card">
                <div class="value-icon">🔬</div>
                <h3>Innovation</h3>
                <p>We embrace innovation and new ideas to advance pharmaceutical research.</p>
            </div>
            <div class="value-card">
                <div class="value-icon">❤️</div>
                <h3>Integrity</h3>
                <p>We uphold the highest standards of integrity and ethical conduct.</p>
            </div>
            <div class="value-card">
                <div class="value-icon">🌟</div>
                <h3>Empowerment</h3>
                <p>We empower individuals with knowledge to make informed health decisions.</p>
            </div>
        </div>
    </section>

    <!-- Team Section -->
    <section class="about-section team-section">
        <div class="about-section-header">
            <div class="section-label">Our Team</div>
            <h2 class="section-title">The People Behind Pharmis Optimus Nexus</h2>
            <div class="divider"></div>
            <p class="section-desc">We are a diverse group of pharmacy students passionate about health education and research.</p>
        </div>
        <div class="team-grid">
            <div class="team-card">
                <div class="team-avatar" style="background: linear-gradient(135deg, #2d6a2d, #4a9e4a);">
                    <span>AJ</span>
                </div>
                <h4>Adetokunbo Johnson</h4>
                <p class="team-role">Director of Public Health</p>
                <p class="team-bio">Passionate about pharmaceutical research and public health education.</p>
            </div>
            <div class="team-card">
                <div class="team-avatar" style="background: linear-gradient(135deg, #2d3a7a, #4a6ab0);">
                    <span>AF</span>
                </div>
                <h4>Adeboye Florence</h4>
                <p class="team-role">Assistant Director of Public Health</p>
                <p class="team-bio">Dedicated to creating engaging health content for diverse audiences.</p>
            </div>
            <div class="team-card">
                <div class="team-avatar" style="background: linear-gradient(135deg, #5a2060, #8a3a90);">
                    <span>AS</span>
                </div>
                <h4>Agbaeze Salome</h4>
                <p class="team-role">Public Relations Officer and Acting Secretary</p>
                <p class="team-bio">Focused on building connections and promoting health awareness.</p>
            </div>
            <div class="team-card">
                <div class="team-avatar" style="background: linear-gradient(135deg, #5a5010, #8a7a20);">
                    <span>BA</span>
                </div>
                <h4>Busari Aminat </h4>
                <p class="team-role">Director of Outreach</p>
                <p class="team-bio">Passionate about evidence-based research and clinical studies.</p>
            </div>
            <div class="team-card">
                <div class="team-avatar" style="background: linear-gradient(135deg, #5a5010, #8a7a20);">
                    <span>OT</span>
                </div>
                <h4>Olaboye Temitope</h4>
                <p class="team-role">Clinical Lead</p>
                <p class="team-bio">Passionate about evidence-based research and clinical studies.</p>
            </div>
            <div class="team-card">
                <div class="team-avatar" style="background: linear-gradient(135deg, #5a5010, #8a7a20);">
                    <span>IH</span>
                </div>
                <h4>Ismail Hameedat</h4>
                <p class="team-role">Wellness Officer</p>
                <p class="team-bio">Passionate about evidence-based research and clinical studies.</p>
            </div>
            <div class="team-card">
                <div class="team-avatar" style="background: linear-gradient(135deg, #5a5010, #8a7a20);">
                    <span>LS</span>
                </div>
                <h4>Lawal Shukroh</h4>
                <p class="team-role">Creative Director and Acting Editor-in-Chief</p>
                <p class="team-bio">Passionate about evidence-based research and clinical studies.</p>
            </div>
            <div class="team-card">
                <div class="team-avatar" style="background: linear-gradient(135deg, #5a5010, #8a7a20);">
                    <span>BE</span>
                </div>
                <h4>Balogun Ezekiel</h4>
                <p class="team-role">Liaison Officer</p>
                <p class="team-bio">Passionate about evidence-based research and clinical studies.</p>
            </div>
            <div class="team-card">
                <div class="team-avatar" style="background: linear-gradient(135deg, #5a5010, #8a7a20);">
                    <span>MY</span>
                </div>
                <h4>Mustapha Yaseer</h4>
                <p class="team-role">Logistics Coordinator</p>
                <p class="team-bio">Passionate about evidence-based research and clinical studies.</p>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="about-section cta-section">
        <div class="cta-content">
            <h2>Join Our Mission</h2>
            <p>Be part of a community dedicated to advancing pharmaceutical knowledge and improving health outcomes.</p>
            <div class="cta-buttons">
                <a href="/contact" class="btn btn-primary">Get in Touch</a>
                <a href="/blog" class="btn btn-outline">Read Our Blog</a>
            </div>
        </div>
    </section>
</div>

<style>
    .about-page {
        padding-bottom: 60px;
    }
    
    /* About Section */
    .about-section {
        padding: 60px 40px;
        max-width: 1200px;
        margin: 0 auto;
    }
    .about-section-header {
        text-align: center;
        margin-bottom: 48px;
    }
    .about-section-header .divider {
        margin: 16px auto 20px;
    }
    .about-section-header .section-desc {
        max-width: 600px;
        margin: 0 auto;
    }
    
    /* Mission Section */
    .about-section-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
    }
    .about-section-text p {
        color: var(--muted);
        margin-bottom: 20px;
        font-size: 1rem;
        line-height: 1.8;
    }
    .about-image-placeholder {
        height: 350px;
        border-radius: var(--radius-lg);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
        font-weight: 600;
        font-family: var(--font-display);
        gap: 16px;
        text-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }
    
    /* Values */
    .values-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 24px;
    }
    .value-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 28px 20px;
        text-align: center;
        transition: var(--transition);
    }
    .value-card:hover {
        transform: translateY(-4px);
        border-color: rgba(241, 109, 120, 0.3);
        box-shadow: var(--shadow-sm);
    }
    .value-icon {
        font-size: 2.5rem;
        margin-bottom: 12px;
    }
    .value-card h3 {
        font-family: var(--font-display);
        font-size: 1.2rem;
        font-weight: 600;
        margin-bottom: 8px;
    }
    .value-card p {
        font-size: 0.875rem;
        color: var(--muted);
        line-height: 1.6;
    }
    
    /* Team */
    .team-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 24px;
    }
    .team-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
        text-align: center;
        transition: var(--transition);
    }
    .team-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-sm);
    }
    .team-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        color: white;
        font-size: 1.5rem;
        font-weight: 700;
    }
    .team-card h4 {
        font-family: var(--font-display);
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 4px;
    }
    .team-role {
        color: var(--blush);
        font-size: 0.85rem;
        font-weight: 500;
        margin-bottom: 8px;
    }
    .team-bio {
        font-size: 0.85rem;
        color: var(--muted);
        line-height: 1.6;
    }
    
    /* CTA */
    .cta-section {
        background: linear-gradient(135deg, var(--bg2), var(--bg3));
        border-radius: var(--radius-lg);
        margin: 40px auto;
        padding: 60px;
        text-align: center;
        max-width: 900px;
    }
    .cta-content h2 {
        font-family: var(--font-display);
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 16px;
        color: var(--text);
    }
    .cta-content p {
        color: var(--muted);
        font-size: 1.1rem;
        margin-bottom: 32px;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
    }
    .cta-buttons {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
    }
    
    @media (max-width: 1024px) {
        .about-section-content {
            grid-template-columns: 1fr;
            gap: 40px;
        }
        .about-image-placeholder {
            height: 250px;
        }
    }
    @media (max-width: 768px) {
        .about-section {
            padding: 40px 20px;
        }
        .values-grid {
            grid-template-columns: 1fr 1fr;
        }
        .team-grid {
            grid-template-columns: 1fr 1fr;
        }
        .cta-section {
            padding: 40px 20px;
            margin: 20px;
        }
        .cta-content h2 {
            font-size: 2rem;
        }
    }
    @media (max-width: 480px) {
        .values-grid {
            grid-template-columns: 1fr;
        }
        .team-grid {
            grid-template-columns: 1fr;
        }
        .about-image-placeholder {
            height: 180px;
            font-size: 1.2rem;
        }
    }
</style>