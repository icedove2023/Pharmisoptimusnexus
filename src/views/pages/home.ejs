<!-- src/views/pages/home.ejs -->
<!-- Hero Section -->
<section class="hero" id="hero" aria-label="Hero section">
    <div class="hero-slides" id="heroSlides">
        <!-- Slides will be generated by JavaScript -->
    </div>

    <!-- Molecule SVG deco -->
    <div class="hero-deco" aria-hidden="true">
        <svg width="460" height="460" viewBox="0 0 460 460" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="230" cy="230" r="60" stroke="#EFD9C7" stroke-width="2"/>
            <circle cx="230" cy="230" r="8" fill="#EFD9C7"/>
            <circle cx="130" cy="130" r="8" fill="#F16D78"/>
            <circle cx="330" cy="130" r="8" fill="#F16D78"/>
            <circle cx="130" cy="330" r="8" fill="#86373E"/>
            <circle cx="330" cy="330" r="8" fill="#86373E"/>
            <circle cx="80" cy="230" r="6" fill="#EFD9C7"/>
            <circle cx="380" cy="230" r="6" fill="#EFD9C7"/>
            <circle cx="230" cy="80" r="6" fill="#EFD9C7"/>
            <circle cx="230" cy="380" r="6" fill="#EFD9C7"/>
            <line x1="230" y1="230" x2="130" y2="130" stroke="#EFD9C7" stroke-width="1.5"/>
            <line x1="230" y1="230" x2="330" y2="130" stroke="#EFD9C7" stroke-width="1.5"/>
            <line x1="230" y1="230" x2="130" y2="330" stroke="#EFD9C7" stroke-width="1.5"/>
            <line x1="230" y1="230" x2="330" y2="330" stroke="#EFD9C7" stroke-width="1.5"/>
            <line x1="230" y1="230" x2="80" y2="230" stroke="#EFD9C7" stroke-width="1"/>
            <line x1="230" y1="230" x2="380" y2="230" stroke="#EFD9C7" stroke-width="1"/>
            <line x1="230" y1="230" x2="230" y2="80" stroke="#EFD9C7" stroke-width="1"/>
            <line x1="230" y1="230" x2="230" y2="380" stroke="#EFD9C7" stroke-width="1"/>
            <circle cx="130" cy="130" r="30" stroke="#F16D78" stroke-width="1" stroke-dasharray="4 4"/>
            <circle cx="330" cy="130" r="30" stroke="#F16D78" stroke-width="1" stroke-dasharray="4 4"/>
        </svg>
    </div>

    <div class="hero-content">
        <div class="hero-tag">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
            </svg>
            Established 2026 · Est. Research Hub
        </div>
        <h1 class="hero-title">
            Pharmis<br><em>Optimus</em><br>Nexus
        </h1>
        <p class="hero-subtitle">Advancing Pharmaceutical Knowledge, Research, and Innovation — connecting scientists, clinicians, and visionaries worldwide.</p>
        <div class="hero-cta">
            <a href="/publications" class="btn btn-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                </svg>
                View Publications
            </a>
            <a href="/blog" class="btn btn-outline">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                Read Blog
            </a>
        </div>
    </div>

    <!-- Slide controls -->
    <button class="hero-arrow prev" id="heroPrev" aria-label="Previous slide">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
    </button>
    <button class="hero-arrow next" id="heroNext" aria-label="Next slide">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"/>
        </svg>
    </button>
    <div class="hero-dots" id="heroDots">
        <!-- Dots will be generated by JavaScript -->
    </div>
</section>

<!-- Stats Bar -->
<div class="stats-bar" role="region" aria-label="Key statistics">
    <div class="stat-item reveal">
        <div class="stat-num" data-count="<%= stats.publications || 0 %>">0</div>
        <div class="stat-label">Publications</div>
    </div>
    <div class="stat-item reveal reveal-delay-1">
        <div class="stat-num" data-count="123">0</div>
        <div class="stat-label">Researchers</div>
    </div>
    <div class="stat-item reveal reveal-delay-2">
        <div class="stat-num" data-count="<%= stats.blogs || 0 %>">0</div>
        <div class="stat-label">Blogs</div>
    </div>
    <div class="stat-item reveal reveal-delay-3">
        <div class="stat-num" data-count="300">0</div>
        <div class="stat-label">Academic Level</div>
    </div>
</div>

<!-- About Section -->
<section id="about" aria-labelledby="about-title">
    <div class="about-grid">
        <div class="about-text">
            <div class="section-label">About Us</div>
            <h2 class="section-title reveal" id="about-title">A Global Nexus for<br>Pharmaceutical Excellence</h2>
            <div class="divider"></div>
            <p class="reveal reveal-delay-1">Pharmis Optimus Nexus is a public health–driven platform founded by passionate 300-level pharmacy students committed to promoting health awareness, pharmaceutical knowledge, and community impact. Our mission is to educate, inform, and inspire individuals through evidence-based health information, research discussions, and public health advocacy.</p>
            <p class="reveal reveal-delay-2">We aim to bridge the gap between pharmaceutical education and community healthcare by creating a space where students, healthcare enthusiasts, and professionals can share ideas, discuss emerging health challenges, and promote healthier lifestyles. Through collaboration, innovation, and a commitment to service, Pharmis Optimus Nexus strives to empower communities with reliable health knowledge while nurturing the next generation of public health-conscious pharmacy professionals.</p>
            <a href="/publications" class="btn btn-primary reveal reveal-delay-3" style="margin-top:8px">
                Explore Publications
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                </svg>
            </a>
        </div>
        <div class="about-cards">
            <div class="about-card reveal" style="grid-column:1/-1">
                <div class="about-card-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
                    </svg>
                </div>
                <h3>Our Mission</h3>
                <p>To advance pharmaceutical research and knowledge by fostering collaboration, innovation, and dissemination of high-quality scientific information.</p>
            </div>
            <div class="about-card reveal reveal-delay-1">
                <div class="about-card-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                        <circle cx="12" cy="12" r="3"/>
                    </svg>
                </div>
                <h3>Our Vision</h3>
                <p>To be a global nexus for pharmaceutical excellence and innovation, improving health outcomes worldwide.</p>
            </div>
            <div class="about-card reveal reveal-delay-2">
                <div class="about-card-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                    </svg>
                </div>
                <h3>Our Goal</h3>
                <p>Empower researchers and professionals through access to quality publications, insights, and collaborative community.</p>
            </div>
        </div>
    </div>
</section>

<!-- Contact Section -->
<section id="contact" aria-labelledby="contact-title">
    <div class="section-header">
        <div class="section-label">Get In Touch</div>
        <h2 class="section-title reveal" id="contact-title">Contact Us</h2>
        <div class="divider"></div>
        <p class="section-desc reveal reveal-delay-1">Have a question, collaboration idea, or want to submit a publication? We'd love to hear from you.</p>
    </div>
    <div class="contact-grid">
        <form id="contactForm" novalidate>
            <div class="contact-form-group reveal">
                <label for="name">Full Name</label>
                <input type="text" id="name" placeholder="Dr. Jane Smith" required />
            </div>
            <div class="contact-form-group reveal reveal-delay-1">
                <label for="email">Email Address</label>
                <input type="email" id="email" placeholder="jane@institution.edu" required />
            </div>
            <div class="contact-form-group reveal reveal-delay-2">
                <label for="message">Message</label>
                <textarea id="message" placeholder="Tell us about your inquiry, research, or collaboration proposal…" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary reveal reveal-delay-3">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="22" y1="2" x2="11" y2="13"/>
                    <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
                Send Message
            </button>
            <div id="form-success" style="display:none;margin-top:16px;color:var(--blush);font-size:0.9rem;font-weight:500;">✓ Message sent successfully!</div>
            <div id="form-error" style="display:none;margin-top:16px;color:#c0392b;font-size:0.9rem;">✕ Failed to send message. Please try again.</div>
        </form>
        <div class="reveal reveal-delay-1">
            <div class="contact-info-item">
                <div class="contact-info-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                        <polyline points="22,6 12,13 2,6"/>
                    </svg>
                </div>
                <div>
                    <h4>Email</h4>
                    <p>pharmisoptimusofficials@gmail.com</p>
                </div>
            </div>
            <div class="contact-info-item">
                <div class="contact-info-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.42 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.13 6.13l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                </div>
                <div>
                    <h4>Phone</h4>
                    <p>+2348147353112</p>
                    <p>+2349028212126</p>
                </div>
            </div>
            <div class="contact-info-item">
                <div class="contact-info-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                        <circle cx="12" cy="10" r="3"/>
                    </svg>
                </div>
                <div>
                    <h4>Address</h4>
                    <p>Faculty of Pharmaceutical Sciences<br>University of Ilorin</p>
                </div>
            </div>
            <div class="social-links">
                <a href="https://www.tiktok.com/@pharmis_optimus" target="_blank" rel="noopener noreferrer" 
                   class="social-link" aria-label="TikTok">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                    </svg>
