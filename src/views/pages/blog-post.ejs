<!-- src/views/pages/blog-post.ejs -->
<% pageStyles = 'blog-post'; %>

<!-- Then include the hero-mini partial -->
<%- include('../partials/hero-mini', { 
    title: post.title,
    category: post.category || 'Blog',
    subtitle: null,
    date: post.published_date,
    authors: post.authors,
    readTime: post.read_time
}) %>
<div class="blog-layout">
    <!-- Main Content -->
    <div class="blog-content-wrapper">
        <article class="blog-article" data-track-view data-post-id="<%= post.id %>">
            <!-- Post Stats Bar -->
            <div class="journal-header">
                <div class="post-meta-bar">
                    <div class="post-stats">
                        <span class="stat-item">
                            <span class="icon">👁️</span>
                            <span class="count" id="viewCount"><%= post.views || 0 %></span>
                        </span>
                        <span class="stat-item like-container" data-post-id="<%= post.id %>">
                            <span class="icon" id="likeIcon">❤️</span>
                            <span class="count" id="likeCount"><%= post.likes || 0 %></span>
                        </span>
                        <span class="stat-item">
                            <span class="icon">💬</span>
                            <span class="count"><%= comments ? comments.length : 0 %></span>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Blog Content -->
            <div class="blog-content-json">
                <% if (post.content && post.content.sections) { %>
                    <% post.content.sections.forEach(section => { %>
                        <% if (section.type === 'heading') { %>
                            <h<%= section.level || 2 %> class="heading-<%= section.level || 2 %>">
                                <%= section.text %>
                            </h<%= section.level || 2 %>>
                        <% } else if (section.type === 'paragraph') { %>
                            <p class="paragraph"><%= section.text %></p>
                        <% } else if (section.type === 'list') { %>
                            <ul class="list-ul">
                                <% section.items.forEach(item => { %>
                                    <li><%= item %></li>
                                <% }) %>
                            </ul>
                        <% } else if (section.type === 'note') { %>
                            <div class="note note-<%= section.variant || 'info' %>">
                                <p><%= section.text %></p>
                            </div>
                        <% } else if (section.type === 'quote') { %>
                            <blockquote class="quote">
                                <p><%= section.text %></p>
                                <% if (section.source) { %>
                                    <div class="quote-source">— <%= section.source %></div>
                                <% } %>
                            </blockquote>
                        <% } else if (section.type === 'image') { %>
                            <div class="image-wrapper">
                                <img src="<%= section.src || '/images/placeholder.jpg' %>" 
                                     alt="<%= section.caption || 'Image' %>" 
                                     loading="lazy" />
                                <% if (section.caption) { %>
                                    <div class="image-caption"><%= section.caption %></div>
                                <% } %>
                            </div>
                        <% } else if (section.type === 'table') { %>
                            <div class="table-wrapper">
                                <table>
                                    <% if (section.headers) { %>
                                        <thead>
                                            <tr><% section.headers.forEach(header => { %>
                                                <th><%= header %></th>
                                            <% }) %></tr>
                                        </thead>
                                    <% } %>
                                    <% if (section.rows) { %>
                                        <tbody>
                                            <% section.rows.forEach(row => { %>
                                                <tr><% row.forEach(cell => { %>
                                                    <td><%= cell %></td>
                                                <% }) %></tr>
                                            <% }) %>
                                        </tbody>
                                    <% } %>
                                </table>
                            </div>
                        <% } %>
                    <% }) %>
                <% } %>
            </div>

            <!-- Tags -->
            <% if (post.tags && post.tags.length) { %>
                <div class="post-tags">
                    <span class="tags-label">Tags:</span>
                    <% post.tags.forEach(tag => { %>
                        <a href="/blog?tag=<%= encodeURIComponent(tag) %>" class="tag-chip">
                            <%= tag %>
                        </a>
                    <% }) %>
                </div>
            <% } %>

            <!-- References -->
            <% if (post.content && post.content.references && post.content.references.length) { %>
                <div class="blog-references-json">
                    <h2 class="heading-2">References</h2>
                    <ul>
                        <% post.content.references.forEach(ref => { %>
                            <li class="reference-item">
                                <%= ref.authors %> (<%= ref.year %>). <%= ref.title %>. <%= ref.source %>
                                <% if (ref.url) { %>
                                    <a href="<%= ref.url %>" target="_blank" rel="noopener noreferrer">Link</a>
                                <% } %>
                            </li>
                        <% }) %>
                    </ul>
                </div>
            <% } %>

            <!-- Social Share -->
            <%- include('../components/social-share', { 
                url: canonicalUrl || '',
                title: post.title
            }) %>

            <!-- Comments -->
            <%- include('../components/comments', { 
                postId: post.id,
                comments: comments || []
            }) %>
        </article>

        <!-- Related Posts -->
        <% if (relatedPosts && relatedPosts.length) { %>
            <section class="related-posts">
                <h3 class="related-title">You might also like</h3>
                <div class="related-grid">
                    <% relatedPosts.slice(0, 3).forEach(related => { %>
                        <a href="/blog/<%= related.slug %>" class="related-card">
                            <div class="related-card-img" style="background-image: url('<%= related.image_url || '/images/placeholder.jpg' %>')"></div>
                            <h4><%= related.title %></h4>
                            <span class="related-date"><%= related.published_date %></span>
                        </a>
                    <% }) %>
                </div>
            </section>
        <% } %>
    </div>

    <!-- Sidebar -->
    <%- include('../partials/sidebar', { 
        categories: categories || [],
        tags: tags || [],
        popularPosts: popularPosts || []
    }) %>
</div>

<style>
    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 24px 0;
        padding: 16px 0;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
    }
    .tags-label {
        font-size: 0.85rem;
        color: var(--muted);
        margin-right: 8px;
        display: flex;
        align-items: center;
    }
    .post-stats {
        display: flex;
        gap: 20px;
        padding: 12px 0;
    }
    .stat-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.9rem;
        color: var(--muted);
    }
    .stat-item .icon {
        font-size: 1.1rem;
    }
    .stat-item .count {
        font-weight: 500;
        color: var(--text);
    }
    .like-container .icon {
        cursor: pointer;
        transition: transform 0.2s;
    }
    .like-container .icon:hover {
        transform: scale(1.2);
    }
    .like-container .icon.liked {
        color: var(--blush);
    }
    .related-posts {
        margin-top: 48px;
        padding-top: 32px;
        border-top: 2px solid var(--border);
    }
    .related-title {
        font-family: var(--font-display);
        font-size: 1.5rem;
        margin-bottom: 20px;
        color: var(--text);
    }
    .related-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 20px;
    }
    .related-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        transition: var(--transition);
        text-decoration: none;
        color: var(--text);
    }
    .related-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-sm);
        border-color: var(--blush);
    }
    .related-card-img {
        height: 120px;
        background-size: cover;
        background-position: center;
    }
    .related-card h4 {
        font-family: var(--font-display);
        font-size: 1rem;
        padding: 12px 16px 4px;
        line-height: 1.3;
    }
    .related-date {
        display: block;
        font-size: 0.78rem;
        color: var(--muted);
        padding: 0 16px 12px;
    }
    @media (max-width: 768px) {
        .related-grid {
            grid-template-columns: 1fr 1fr;
        }
        .post-stats {
            gap: 12px;
        }
    }
    @media (max-width: 480px) {
        .related-grid {
            grid-template-columns: 1fr;
        }
        .post-stats {
            flex-wrap: wrap;
            gap: 8px;
        }
    }
</style>

<!-- Likes JavaScript -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const likeContainer = document.querySelector('.like-container');
        if (!likeContainer) return;
        
        const postId = likeContainer.dataset.postId;
        const likeIcon = document.getElementById('likeIcon');
        const likeCount = document.getElementById('likeCount');
        
        if (!likeIcon || !likeCount) return;
        
        // Check if already liked this session
        const liked = sessionStorage.getItem(`liked_${postId}`) === 'true';
        if (liked) {
            likeIcon.classList.add('liked');
        }
        
        likeIcon.addEventListener('click', async function() {
            try {
                const response = await fetch(`/api/likes/${postId}`, {
                    method: 'POST'
                });
                const data = await response.json();
                
                if (data.success) {
                    likeCount.textContent = data.likes;
                    if (data.liked) {
                        this.classList.add('liked');
                        sessionStorage.setItem(`liked_${postId}`, 'true');
                    } else {
                        this.classList.remove('liked');
                        sessionStorage.removeItem(`liked_${postId}`);
                    }
                }
            } catch (error) {
                console.error('Error toggling like:', error);
            }
        });
    });
</script>