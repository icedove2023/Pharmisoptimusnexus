<!-- src/views/components/related-posts.ejs -->
<% if (posts && posts.length) { %>
    <section class="related-posts-section">
        <div class="related-posts-header">
            <h3 class="related-posts-title">
                <span class="title-icon">📚</span>
                You Might Also Like
            </h3>
            <a href="/blog" class="view-all-link">View All →</a>
        </div>
        
        <div class="related-posts-grid">
            <% posts.slice(0, 3).forEach((post, index) => { %>
                <article class="related-post-card" style="animation-delay: <%= index * 0.1 %>s">
                    <!-- Make sure slug exists -->
<% if (post.slug) { %>
    <a href="/blog/<%= post.slug %>" class="btn-sm">Read More</a>
<% } else { %>
    <a href="/blog/<%= post.id %>" class="btn-sm">Read More</a>
<% } %>
                        <div class="related-post-image" style="background-image: url('<%= post.image_url || '/images/placeholder.jpg' %>')">
                            <% if (post.category) { %>
                                <span class="related-post-category"><%= post.category %></span>
                            <% } %>
                        </div>
                        <div class="related-post-content">
                            <h4 class="related-post-title"><%= post.title %></h4>
                            <div class="related-post-meta">
                                <span class="related-post-date"><%= post.published_date %></span>
                                <span class="related-post-read-time">📖 <%= post.read_time || '5 min' %></span>
                            </div>
                        </div>
                    </a>
                </article>
            <% }) %>
        </div>
    </section>
<% } %>

<style>
    .related-posts-section {
        margin-top: 48px;
        padding-top: 32px;
        border-top: 2px solid var(--border);
    }
    .related-posts-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }
    .related-posts-title {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .title-icon {
        font-size: 1.3rem;
    }
    .view-all-link {
        color: var(--blush);
        font-size: 0.9rem;
        text-decoration: none;
        transition: color var(--transition);
    }
    .view-all-link:hover {
        color: var(--text);
    }
    .related-posts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 24px;
    }
    .related-post-card {
        opacity: 0;
        animation: fadeInUp 0.6s ease forwards;
    }
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .related-post-link {
        display: block;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        transition: var(--transition);
        text-decoration: none;
        color: var(--text);
        height: 100%;
    }
    .related-post-link:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-sm);
        border-color: rgba(241, 109, 120, 0.3);
    }
    .related-post-image {
        height: 160px;
        background-size: cover;
        background-position: center;
        position: relative;
    }
    .related-post-category {
        position: absolute;
        top: 12px;
        left: 12px;
        background: rgba(23, 34, 43, 0.85);
        color: var(--cream);
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 4px 12px;
        border-radius: 99px;
        backdrop-filter: blur(4px);
    }
    .related-post-content {
        padding: 16px;
    }
    .related-post-title {
        font-family: var(--font-display);
        font-size: 1.05rem;
        font-weight: 600;
        line-height: 1.3;
        margin-bottom: 8px;
        color: var(--text);
    }
    .related-post-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.78rem;
        color: var(--muted);
    }
    .related-post-date {
        display: flex;
        align-items: center;
        gap: 4px;
    }
    .related-post-read-time {
        display: flex;
        align-items: center;
        gap: 4px;
    }
    
    @media (max-width: 768px) {
        .related-posts-grid {
            grid-template-columns: 1fr 1fr;
        }
        .related-posts-title {
            font-size: 1.2rem;
        }
    }
    @media (max-width: 480px) {
        .related-posts-grid {
            grid-template-columns: 1fr;
        }
        .related-post-image {
            height: 140px;
        }
    }
</style>